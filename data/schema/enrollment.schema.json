{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/afromero/riasec-co/data/schema/enrollment.schema.json",
  "title": "SNIES Enrollment Record",
  "description": "Enrollment statistics from Colombia's SNIES registry, by CINE field, department, and year",
  "type": "object",
  "required": [
    "year",
    "cine_amplio",
    "departamento",
    "enrolled"
  ],
  "properties": {
    "year": {
      "type": "integer",
      "minimum": 2010,
      "maximum": 2030,
      "description": "Academic year"
    },
    "cine_amplio": {
      "type": "string",
      "description": "CINE F 2013 AC broad field"
    },
    "cine_especifico": {
      "type": ["string", "null"],
      "description": "CINE F 2013 AC specific field"
    },
    "departamento": {
      "type": "string",
      "description": "Department"
    },
    "sector": {
      "type": ["string", "null"],
      "enum": ["Oficial", "Privado", null],
      "description": "Sector"
    },
    "nivel_formacion": {
      "type": ["string", "null"],
      "description": "Education level"
    },
    "sexo": {
      "type": ["string", "null"],
      "enum": ["Hombre", "Mujer", null],
      "description": "Gender"
    },
    "enrolled": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of enrolled students"
    },
    "graduated": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Number of graduates"
    }
  }
}
